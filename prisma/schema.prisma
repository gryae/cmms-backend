generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users      User[]
  assets     Asset[]
  workOrders WorkOrder[] // 👈 TAMBAH INI
}

enum Role {
  ADMIN
  SUPERVISOR
  TECHNICIAN
  USER
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  workOrders        WorkOrder[]        @relation("AssignedWorkOrders") // 👈 TAMBAH INI
  comments          WorkOrderComment[] // 👈 TAMBAH INI
  createdWorkOrders WorkOrder[]        @relation("CreatedWorkOrders") // ✅
  subscription  PushSubscription[]
}



model Asset {
  id       String @id @default(uuid())
  tenantId String

  name            String
  code            String
  branch          String
  location        String
  procurementYear Int

  category String?

  isActive        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  workOrders WorkOrder[]

  @@unique([tenantId, code])
}

enum WorkOrderStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  DONE
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

model WorkOrder {
  id          String          @id @default(uuid())
  tenantId    String
  title       String
  description String?
  priority    Priority
  status      WorkOrderStatus @default(OPEN)
  completedAt DateTime?

  assetId    String?
  assignedTo String?
  createdBy  String?
  creator    User?   @relation("CreatedWorkOrders", fields: [createdBy], references: [id])

  createdAt DateTime  @default(now())
  dueDate   DateTime?

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  asset    Asset? @relation(fields: [assetId], references: [id])
  assignee User?  @relation("AssignedWorkOrders", fields: [assignedTo], references: [id])

  attachments WorkOrderAttachment[]
  parts       WorkOrderPart[]

  comments WorkOrderComment[]
}

model WorkOrderAttachment {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])

  fileName String
  fileUrl  String
  mimeType String
  size     Int

  createdAt DateTime @default(now())
}

model SparePart {
  id       String @id @default(uuid())
  tenantId String

  name       String
  partNumber String?
  unit       String
  stock      Int
  minStock   Int
  usages     WorkOrderPart[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkOrderPart {
  id String @id @default(uuid())

  tenantId    String
  workOrderId String
  sparePartId String
  quantity    Int

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  sparePart SparePart @relation(fields: [sparePartId], references: [id])

  createdAt DateTime @default(now())
}

model WorkOrderComment {
  id          String @id @default(uuid())
  workOrderId String
  userId      String
  message     String

  createdAt DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model PushSubscription{
  id          String @id @default(uuid())
  userId      String
  endpoint    String @unique
  keys        Json
  createdAt   DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
}