<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Work Order Created</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f7fa;font-family:'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table width="100%" border="0" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding:40px 10px;">
        <table width="600" border="0" cellpadding="0" cellspacing="0" style="background-color:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 10px 25px rgba(0,0,0,0.05);border:1px solid #e2e8f0;">
          
          <tr>
            <td style="background-color:#0B0F19; padding:50px 24px; text-align:center;">
              <div style="font-size:32px; font-weight:800; letter-spacing:1px; line-height:1; margin-bottom:8px;">
                <span style="color:#ffffff;">LAPOR</span><span style="color:#00A3E0;">SKKKJ</span>
              </div>
              <div style="color:rgba(255,255,255,0.5); font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:2px; margin-top:10px;">
                Maintenance Management System
              </div>
            </td>
          </tr>

          <tr>
            <td style="background-color:#00A3E0; padding:12px; text-align:center; color:#ffffff; font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:1px;">
              New Work Order Created 🛠
            </td>
          </tr>

          <tr>
            <td style="padding:45px 40px; color:#334155; line-height:1.6;">
              <h3 style="margin-top:0; color:#1e293b; font-size:20px;">Work Order Notification</h3>
              <p style="font-size:16px;">
                Halo, <br>Work order baru telah berhasil dibuat oleh <strong>{{creator}}</strong>. Berikut rincian tugasnya:
              </p>

              <div style="background-color:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:25px; margin:30px 0;">
                <table width="100%" border="0" cellpadding="0" cellspacing="0" style="font-size:15px;">
                  <tr>
                    <td width="40%" style="padding-bottom:12px; color:#64748b; font-weight:500;">Title</td>
                    <td style="padding-bottom:12px; color:#1e293b; font-weight:700;">{{title}}</td>
                  </tr>
                  <tr>
                    <td width="40%" style="padding-bottom:12px; color:#64748b; font-weight:500;">Priority</td>
                    <td style="padding-bottom:12px; color:#1e293b; font-weight:700;">{{priority}}</td>
                  </tr>
                  {{#if asset}}
                  <tr>
                    <td width="40%" style="padding-bottom:12px; color:#64748b; font-weight:500;">Asset Unit</td>
                    <td style="padding-bottom:12px; color:#1e293b; font-weight:700;">{{asset}}</td>
                  </tr>
                  {{/if}}
                  {{#if dueDate}}
                  <tr>
                    <td width="40%" style="color:#64748b; font-weight:500;">Due Date</td>
                    <td style="color:#1e293b; font-weight:700;">{{dueDate}}</td>
                  </tr>
                  {{/if}}
                </table>
              </div>

              <div style="text-align:center; margin-top:40px;">
                <a href="{{link}}"
                   style="background-color:#00A3E0; color:#ffffff; padding:18px 40px; border-radius:10px; text-decoration:none; font-weight:700; font-size:16px; display:inline-block;">
                  OPEN WORK ORDER
                </a>
              </div>
            </td>
          </tr>

          <tr>
            <td style="padding:0 40px 40px 40px; text-align:center;">
              <p style="font-size:12px; color:#94a3b8; margin:0; border-top:1px solid #f1f5f9; padding-top:20px;">
                &copy; 2026 <strong>LAPOR SKKKJ</strong><br>
               
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>